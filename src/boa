function print-info () {

    [[ "$1" == "" || "$1" == "info" ]] && echo -e "\e[32m[INFO]\e[0m $2"
    [[ "$1" == "warning" ]] && echo -e "\e[33m[WARN]\e[0m $2"
    [[ "$1" == "error" ]] && { echo -e "\e[31m[ERROR]\e[0m $2" ; exit 1 ; }

}

function generateChangelog () {

    # Get the list of unique commit dates in reverse chronological order
    _commitDates=$(git log --date=short --pretty=format:'%ad' | sort -ur)
    _fistCommitDate=$(git log --date=short --pretty=format:'%ad' | tail -n 1)

    _changelogFile="debian/changelog"

    if test -f "$_changelogFile" ; then rm -f "$_changelogFile" ; fi

    # Iterate over each date # 2089492222
    for d in $_commitDates; do

        _gitBranch=$(git rev-parse --abbrev-ref HEAD)

        # Check if the branch is for development/testing or main branch.
        case "$_gitBranch" in
            main|master|stable|release|production ) _releaseType="stable"   ;;
            dev|development|unstable|testing      ) _releaseType="unstable" ;;
            *                                     ) _releaseType="stable"   ;;
        esac

        # Get the list of commits for the current date
        _commits=$(git log "${_gitBranch}" --since="$d 00:00" --until="$d 23:59" --pretty=format:'%h')

        test -n "$_commits" || _commits=$(git log --since="$d 00:00" --pretty=format:'%h')

        # Get the author name and email from the latest commit of the day
        _latestCommit=$(echo "$_commits" | head -n 1)
        _authorName=$(git log -1 --format='%an' "$_latestCommit")
        _authorEmail=$(git log -1 --format='%ae' "$_latestCommit")

        # Count the number of commits and reverse the order
        mapfile -t commitCount < <(git rev-list HEAD --since="$_fistCommitDate" --until="$d 23:59")

        _major=0 ; _minor=0 ; _patch=0

        for ((i=0; i<${#commitCount[@]}; i++)); do
            _patch=$(( _patch + 1 ))
            (( _patch == changelogIteration )) && { _patch=0 ; _minor=$(( _minor + 1 )) ; }
            (( _minor == changelogIteration )) && { _minor=0 ; _major=$(( _major + 1 )) ; }
        done

        versionCode="${_major}.${_minor}.${_patch}"

        # Format the date for the changelog entry
        _changelogDate=$(date -d "$d" '+%a, %d %b %Y')

        # Start the changelog entry
        {

            echo "${packageName} (${versionCode}) ${_releaseType}; urgency=$changelogUrgency"
            echo ""

            # Add each commit message to the changelog entry
            for commit in $_commits; do
                _commitMessage=$(git log -1 --pretty=format:'%s' "$commit")
                echo "  * $_commitMessage"
            done

            # End the changelog entry
            echo ""
            echo " -- ${_authorName} <${_authorEmail}>  ${_changelogDate} 00:00:00 +0000"
            echo ""

        } | tee -a "$_changelogFile" > /dev/null

        # Amend the version number to the version file int the root directory
    done

    _currentVersion=$(grep -oP '(?<=\()\d+\.\d+\.\d+(?=\))' "$_changelogFile" | head -n 1)

    echo "${_currentVersion}" | tee doc/version > /dev/null

}

# Uncomment for debugging
#set -euox pipefail

appName="boa"
appVersion=$(cat /usr/share/doc/boa/version 2> /dev/null || echo "unknown")

[[ ! -f "./.env" ]] &&
print-info "error" ".env file not found! Please create one based on the .env.example file."

source ./.env

### Build options ###
build="${BUILD:-binary}"
preClean="${PRE_CLEAN:-true}"
postClean="${POST_CLEAN:-false}"
checkBuildDeps="${CHECKBUILDDEPS:-true}"
jobs="${JOBS:-auto}"

### Signing options ###
signEnable="${SIGN:-false}"
signBackend="${BACKEND:-auto}"
signKeyID="${KEYID:-}"
signPause="${PAUSE:-false}"

### Changelog options ###
changelogEnable="${CHANGELOG_ENABLE:-true}"
changelogIteration="${CHANGELOG_ITERATION:-15}"
changelogUrgency="${CHANGELOG_URGENCY:-low}"

packageName="$(basename "$(pwd)")"

cmd="dpkg-buildpackage"

case "$build" in
    source|binary|source,binary ) cmd+=" --build=$build"                ;;
    *) echo "Error: Invalid build type specified in boa.yaml!" ; exit 1 ;;
esac

# Verify pre-clean option
[[ "$preClean" == "true" ]] && cmd+=" --pre-clean"
[[ "$preClean" == "false" ]] && cmd+=" --no-pre-clean"

# Verify post-clean option
[[ "$postClean" == "true" ]] && cmd+=" --post-clean"
[[ "$postClean" == "false" ]] && cmd+=" --no-post-clean"

[[ "$checkBuildDeps" == "true" ]] && cmd+=" --check-builddeps"

# Verify that the jobs value is valid
case "$jobs" in
    auto                        ) cmd+=" --jobs=$jobs" ;;
    [0-9]*[0-9]                 )
        test "$jobs" -gt "$(nproc --all)" &&
        print-info "warning" "Jobs value exceeds available CPU/Threads!"
        cmd+=" --jobs=$jobs"
    ;;
    *                           )
        test "$jobs" -ge 1 ||
        print-info "warning" "Invalid jobs value specified in boa.yaml!"
    ;;
esac

[[ "$signEnable" == "false" ]] && cmd+=" --no-sign"

# Only add signing options if signing is enabled
if [[ "$signEnable" == "true"  ]] ; then

    case "$signBackend" in
        sop|sq|gpg              ) cmd+=" --sign-backend=$signBackend" ;;
        auto                    ) ;;
        *                       )
            echo "Error: Invalid sign backend specified in boa.yaml!" ; exit 1
        ;;
    esac

    if [[ -z "$signKeyID" ]]; then
        print-info "erroror" "No signing key ID specified in .env file!"
    else
        cmd+=" --sign-keyid=$signKeyID"
    fi

    [[ "$signPause" == "true" ]] && cmd+=" --sign-pause"
fi

[[ "$changelogEnable" == "true" ]] && generateChangelog

eval "$cmd" || print-info "error" "Build process failed!"

print-info "info" "$appName v$appVersion build process completed successfully."

exit 0

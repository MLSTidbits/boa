function usage () { echo "$helpInfo" ; exit "${1:-0}"; }

function event-handler () {
    local event="$1"
    local msg="$2"

    case "$event" in
        error   ) echo "error: $msg" >&2 ; exit 1 ;;
        warning ) echo "warning: $msg" >&2        ;;
        info    ) echo "info: $msg"               ;;
    esac
}

function flush_block () {
    [[ -z "$version" ]] && return

    # Convert date to RFC 2822 format (debian/changelog requirement)
    # auto-changelog dates are like "5 April 2026" or "29 March 2026"
    local rfc_date
    rfc_date=$(date --date="$date_str" -R 2>/dev/null) || rfc_date="$(date -R)"

    {
        echo "${currentPackage} (${version}) ${releaseType}; urgency=${urgency}"
        echo ""
        for entry in "${entries[@]}"; do
            echo "  * ${entry}"
        done
        echo ""
        echo " -- ${maintainer}  ${rfc_date}"
        echo ""
    } >> "$output"
}

# Uncomment for debugging
#set -exo pipefail

source /etc/os-release

input="CHANGELOG.md"
output="debian/changelog"
currentPackage="$(basename "$(pwd)")"
releaseType="${VERSION_CODENAME:-unstable}"
urgency="medium"

debianUser="${DEBFULLNAME:-$(git config user.name 2>/dev/null || echo "")}"
debianEmail="${DEBEMAIL:-$(git config user.email 2>/dev/null || echo "")}"

maintainer="$debianUser <$debianEmail>"

appName="boa"
appVersion="1.7"
appDescription="Convert auto-changelog CHANGELOG.md to debian/changelog format"
appAuthor="Michael Schaecher <michaelschaecher@mlstidbits.com>"

versionInfo="$appName $appVersion - $appDescription"
licenseInfo="Copyright (c) 2026 $appAuthor under the GPL-3.0+ License (https://www.gnu.org/licenses/gpl-3.0.html)"

helpInfo="$(cat << EOF
$versionInfo

Usage: $0 [OPTIONS] args...

Options:
    -i, --input <file>       Input CHANGELOG.md (default: CHANGELOG.md)
    -o, --output <file>      Output file (default: debian/changelog)
    -p, --package <name>     Package name (default: read from debian/control)
    -r, --release <d>        Release type (default: unstable)
    -u, --urgency <u>        Urgency (default: medium)
    -m, --maintainer <m>     Maintainer (default: from git config or DEBEMAIL/DEBFULLNAME)
    -h, --help               Show this help
    -v, --version            Show version information

$licenseInfo
EOF
)"

command -v auto-changelog >/dev/null 2>&1 || event-handler \
"error" "auto-changelog not found. Please install it with 'npm install -g auto-changelog'"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--input      ) input="$2"          ; shift 2 ;;
        -o|--output     ) output="$2"         ; shift 2 ;;
        -p|--package    ) currentPackage="$2" ; shift 2 ;;
        -r|--release    ) releaseType="$2"    ; shift 2 ;;
        -u|--urgency    ) urgency="$2"        ; shift 2 ;;
        -m|--maintainer ) maintainer="$2"     ; shift 2 ;;
        -h|--help       ) usage 0                       ;;
        -v|--version    ) echo "$versionInfo" ; exit 0  ;;
        *)
            event-handler "error" "unknown option: $1. Use -h/--help for usage information."
            ;;
    esac
done

[[ -n "$currentPackage" ]] || event-handler "error" "could not determine package name. Use -p/--package."

[[ -n "$maintainer" ]] || event-handler \
"error" "could not determine maintainer. Use -m/--maintainer or set git config user.name and user.email"

[[ -f "$input" ]] || event-handler "error" "input file not found: $input"

mkdir -p "$(dirname "$output")"

# State
version=""
date_str=""
declare -a entries=()
first_block=true

# Wipe output file
: > "$output"

while IFS= read -r line; do
    # Match version header: #### [1.6](...) or ### [1.0](...)
    if [[ "$line" =~ ^#{2,4}[[:space:]]+\[([^]]+)\] ]]; then
        # Flush previous block
        [[ -n "$version" ]] && flush_block
        version="${BASH_REMATCH[1]}"
        entries=()
        date_str=""
        first_block=false
        continue
    fi

    # Match version header without link (e.g. "#### 0.0")
    if [[ "$line" =~ ^#{2,4}[[:space:]]+([0-9]+\.[0-9]+[^[:space:]]*)$ ]]; then
        [[ -n "$version" ]] && flush_block
        version="${BASH_REMATCH[1]}"
        entries=()
        date_str=""
        first_block=false
        continue
    fi

    # Match date line: "> 5 April 2026"
    if [[ "$line" =~ ^\>[[:space:]]+(.+)$ ]]; then
        date_str="${BASH_REMATCH[1]}"
        continue
    fi

    # Match commit entry: "- some message [`abc1234`](url)"
    if [[ "$line" =~ ^\-[[:space:]]+ ]]; then
        # Strip leading "- " and trailing commit link [`hash`](url)
        msg="${line#- }"
        msg="${msg% \[\`[0-9a-f]*\`\](*\)}"
        [[ -n "$msg" ]] && entries+=("$msg")
        continue
    fi

done < "$input"

# Flush final block
[[ -n "$version" ]] && flush_block

event-handler "info" "changelog conversion complete: $output"

exit 0

function usage () { echo "$helpInfo" ; exit "${1:-0}"; }

function event-handler () {
    local event="$1"
    local msg="$2"

    case "$event" in
        error   ) echo "error: $msg" >&2 ; exit 1 ;;
        warning ) echo "warning: $msg" >&2        ;;
        info    ) echo "info: $msg"               ;;
    esac
}

function flush_block () {
    [[ -z "$version" ]] && return

    # Convert date to RFC 2822 format (debian/changelog requirement)
    # auto-changelog dates are like "5 April 2026" or "29 March 2026"
    local rfc_date
    rfc_date=$(date --date="$date_str" -R 2>/dev/null) || rfc_date="$(date -R)"

    {
        echo "${PACKAGE} (${version}) ${DISTRIBUTION}; urgency=${URGENCY}"
        echo ""
        for entry in "${entries[@]}"; do
            echo "  * ${entry}"
        done
        echo ""
        echo " -- ${MAINTAINER}  ${rfc_date}"
        echo ""
    } >> "$OUTPUT"
}

set -euo pipefail

INPUT="CHANGELOG.md"
OUTPUT="debian/changelog"
PACKAGE="$(basename "$(pwd)")"
DISTRIBUTION="unstable"
URGENCY="medium"
MAINTAINER=""

appName="boa"
appVersion="1.6"
appDescription="Convert auto-changelog CHANGELOG.md to debian/changelog format"
appAuthor="Michael Schaecher <michaelschaecher@mlstidbits.com>"

helpInfo="$(cat << EOF
changelog-to-deb — convert auto-changelog CHANGELOG.md to debian/changelog

Usage: changelog-to-deb [OPTIONS]

Options:
    -i, --input <file>       Input CHANGELOG.md (default: CHANGELOG.md)
    -o, --output <file>      Output file (default: debian/changelog)
    -p, --package <name>     Package name (default: read from debian/control)
    -d, --distribution <d>   Distribution (default: unstable)
    -u, --urgency <u>        Urgency (default: medium)
    -m, --maintainer <m>     Maintainer (default: from git config or DEBEMAIL/DEBFULLNAME)
    -h, --help               Show this help
EOF
)"

command -v auto-changelog >/dev/null 2>&1 || event-handler \
"error" "auto-changelog not found. Please install it with 'npm install -g auto-changelog'"

if [[ -z "$MAINTAINER" ]]; then
    NAME="${DEBFULLNAME:-$(git config user.name 2>/dev/null || echo "")}"
    EMAIL="${DEBEMAIL:-$(git config user.email 2>/dev/null || echo "")}"
    if [[ -n "$NAME" && -n "$EMAIL" ]]; then
        MAINTAINER="${NAME} <${EMAIL}>"
    fi
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--input)        INPUT="$2";        shift 2 ;;
        -o|--output)       OUTPUT="$2";       shift 2 ;;
        -p|--package)      PACKAGE="$2";      shift 2 ;;
        -d|--distribution) DISTRIBUTION="$2"; shift 2 ;;
        -u|--urgency)      URGENCY="$2";      shift 2 ;;
        -m|--maintainer)   MAINTAINER="$2";   shift 2 ;;
        -h|--help)         usage 0 ;;
        *)
            echo "error: unknown option: $1" >&2
            usage 1
            ;;
    esac
done

if [[ -z "$PACKAGE" ]]; then
    [[ -f debian/control ]] && PACKAGE=$(grep -m1 '^Source:' debian/control | awk '{print $2}')
fi

[[ -n "$PACKAGE" ]] || event-handler "error" "could not determine package name. Use -p/--package."

[[ -n "$MAINTAINER" ]] || event-handler \
"error" "could not determine maintainer. Use -m/--maintainer or set git config user.name and user.email"

[[ -f "$INPUT" ]] || event-handler "error" "input file not found: $INPUT"

mkdir -p "$(dirname "$OUTPUT")"

# State
version=""
date_str=""
declare -a entries=()
first_block=true

# Wipe output file
: > "$OUTPUT"

while IFS= read -r line; do
    # Match version header: #### [1.6](...) or ### [1.0](...)
    if [[ "$line" =~ ^#{2,4}[[:space:]]+\[([^]]+)\] ]]; then
        # Flush previous block
        if [[ -n "$version" ]]; then
            flush_block
        fi
        version="${BASH_REMATCH[1]}"
        entries=()
        date_str=""
        first_block=false
        continue
    fi

    # Match version header without link (e.g. "#### 0.0")
    if [[ "$line" =~ ^#{2,4}[[:space:]]+([0-9]+\.[0-9]+[^[:space:]]*)$ ]]; then
        if [[ -n "$version" ]]; then
            flush_block
        fi
        version="${BASH_REMATCH[1]}"
        entries=()
        date_str=""
        first_block=false
        continue
    fi

    # Match date line: "> 5 April 2026"
    if [[ "$line" =~ ^\>[[:space:]]+(.+)$ ]]; then
        date_str="${BASH_REMATCH[1]}"
        continue
    fi

    # Match commit entry: "- some message [`abc1234`](url)"
    if [[ "$line" =~ ^\-[[:space:]]+ ]]; then
        # Strip leading "- " and trailing commit link [`hash`](url)
        msg="${line#- }"
        msg=$(echo "$msg" | sed 's/ \[`[0-9a-f]*`\]([^)]*)$//')
        [[ -n "$msg" ]] && entries+=("$msg")
        continue
    fi

done < "$INPUT"

# Flush final block
[[ -n "$version" ]] && flush_block

echo "Written: $OUTPUT"
